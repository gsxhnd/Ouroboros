{
  "name": "ourboros",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "preview": "npm run preview -w web",
    "lint": "npm run lint -w web",
    "format": "npm run format -w web",
    "typecheck": "npm run typecheck -w web",
    "tauri": "tauri dev --config crates/ourboros-tauri/tauri.conf.json",
    "tauri:dev": "tauri dev --config crates/ourboros-tauri/tauri.conf.json",
    "tauri:build": "tauri build --config crates/ourboros-tauri/tauri.conf.json",
    "cargo:check": "cargo check --workspace",
    "cargo:build": "cargo build --workspace"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
